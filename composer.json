{
	"type": "wordpress-plugin",
	"autoload": {
		"classmap": [
			"includes/"
		],
		"files": [
			"includes/functions.php"
		]
	},
	"require": {
		"aws/aws-sdk-php": "^3.331.0"
	},
	"extra": {
		"aws/aws-sdk-php": [
			"S3"
		]
	},
	"scripts": {
		"package": [
			"composer scope-release",
			"cd .. && zip -r nobloat-s3-offload.zip nobloat-s3-offload -x 'nobloat-s3-offload/.git/*' -x 'nobloat-s3-offload/.gitignore' -x 'nobloat-s3-offload/.github/*' -x 'nobloat-s3-offload/composer.json' -x 'nobloat-s3-offload/composer.lock' -x 'nobloat-s3-offload/*.md' -x 'nobloat-s3-offload/.phpcs.xml' -x 'nobloat-s3-offload/.editorconfig' -x 'nobloat-s3-offload/scoper.inc.php' -x 'nobloat-s3-offload/docs/*' -x 'nobloat-s3-offload/.claude/*' -x '*.DS_Store'"
		],
		"pre-autoload-dump": "Aws\\Script\\Composer\\Composer::removeUnusedServices",
		"scope-release": [
			"rm -rf vendor",
			"composer install --no-dev --optimize-autoloader --prefer-dist",
			"~/.composer/vendor/bin/php-scoper add-prefix",
			"rm -rf vendor",
			"mv build/vendor vendor",
			"rm -rf build",
			"composer dump-autoload --classmap-authoritative"
		],
		"scope-dev": [
			"rm -rf vendor",
			"composer install",
			"~/.composer/vendor/bin/php-scoper add-prefix",
			"rm -rf vendor",
			"mv build/vendor vendor",
			"rm -rf build",
			"composer dump-autoload --classmap-authoritative"
		]
	},
	"require-dev": {},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"platform": {
			"php": "8.1"
		}
	}
}
